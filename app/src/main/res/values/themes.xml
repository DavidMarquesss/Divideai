    <style name="Animation.DivideAi.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Widget.DivideAi.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.DivideAi.BottomNavigationView</item>
    </style>

    <style name="ThemeOverlay.DivideAi.BottomNavigationView" parent="">
        <item name="colorSecondaryContainer">@color/porcelain</item>
        <item name="colorSurfaceContainer">@color/muted_teal</item>
    </style>


    <style name="Widget.DivideAi.Toolbar.Primary" parent="Widget.Material3.Toolbar.Surface">
        <item name="materialThemeOverlay">@style/ThemeOverlay.DivideAi.Toolbar.Surface</item>
    </style>

    <style name="ThemeOverlay.DivideAi.Toolbar.Surface" parent="">
        <item name="colorSurface">@color/muted_teal</item>
        <item name="colorSurfaceContainer">@color/muted_teal</item>
        <item name="colorOnSurface">@color/grafite</item>
    </style>

    <style name="Widget.DivideAi.AppBarLayout.Primary" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">@color/muted_teal</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/muted_teal</item>

        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <item name="postSplashScreenTheme">@style/Theme.DivideAi</item>
    </style>


    <style name="Widget.DivideAi.Icon" parent="">
        <item name="tint">?attr/colorOnSurface</item>
    </style>

    <style name="Widget.DivideAi.SearchBar" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">999dp</item>
        <item name="boxCornerRadiusTopEnd">999dp</item>
        <item name="boxCornerRadiusBottomStart">999dp</item>
        <item name="boxCornerRadiusBottomEnd">999dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="startIconDrawable">@drawable/ic_search_24dp</item>
        <item name="startIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="Widget.DivideAi.SearchBar.Input" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:inputType">textNoSuggestions</item>
        <item name="android:paddingStart">48dp</item>
        <item name="android:paddingEnd">16dp</item>

        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:gravity">center_vertical</item>

        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="android:background">@null</item>
    </style>
